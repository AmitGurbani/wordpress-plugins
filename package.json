{
  "name": "wordpress-plugins",
  "private": true,
  "license": "GPL-2.0-or-later",
  "author": "Amit Gurbani",
  "repository": {
    "type": "git",
    "url": "https://github.com/AmitGurbani/wordpress-plugins.git"
  },
  "homepage": "https://github.com/AmitGurbani/wordpress-plugins#readme",
  "bugs": {
    "url": "https://github.com/AmitGurbani/wordpress-plugins/issues"
  },
  "packageManager": "pnpm@10.6.2",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "test:e2e": "turbo run test:e2e",
    "lint": "turbo run lint",
    "format": "biome format --write .",
    "check": "turbo run check",
    "prepare": "simple-git-hooks"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,json,css}": "biome check --write --no-errors-on-unmatched"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.9",
    "lint-staged": "^16.4.0",
    "simple-git-hooks": "^2.13.1",
    "turbo": "^2.8.0"
  }
}
