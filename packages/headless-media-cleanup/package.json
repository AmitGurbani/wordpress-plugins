{
  "name": "headless-media-cleanup",
  "version": "1.1.0",
  "private": true,
  "description": "Auto-delete orphaned WooCommerce media when images are removed from products, variations, and taxonomy terms",
  "scripts": {
    "build": "wpts build src/plugin.ts -o dist --clean --zip",
    "dev": "wpts watch src/plugin.ts -o dist",
    "wp-env:start": "wp-env start",
    "wp-env:stop": "wp-env stop",
    "wp-env:clean": "wp-env clean all",
    "lint": "biome lint src/",
    "check": "biome check src/"
  },
  "devDependencies": {
    "@wordpress/env": "^10.0.0",
    "@amitgurbani/wpts": "workspace:*"
  }
}
