---
import type { Faq } from "../data/plugins";

interface Props {
  faqs: Faq[];
}

const { faqs } = Astro.props;
---

{faqs.length > 0 && (
  <section class="py-16 px-6">
    <div class="max-w-4xl mx-auto">
      <h2 class="text-2xl font-bold mb-8">FAQ</h2>
      <div class="space-y-4">
        {faqs.map((faq) => (
          <details class="group rounded-xl border border-border bg-surface-card">
            <summary class="px-6 py-4 cursor-pointer font-medium flex items-center justify-between list-none">
              {faq.question}
              <svg class="w-5 h-5 text-text-muted group-open:rotate-180 transition-transform shrink-0 ml-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
              </svg>
            </summary>
            <div class="px-6 pb-4 text-sm text-text-muted leading-relaxed">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>
)}
