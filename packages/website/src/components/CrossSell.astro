---
import PluginCard from "./PluginCard.astro";
import { getOtherPlugins } from "../data/plugins";

interface Props {
  currentSlug: string;
}

const { currentSlug } = Astro.props;
const others = getOtherPlugins(currentSlug).slice(0, 4);
---

<section class="py-16 px-6">
  <div class="max-w-6xl mx-auto">
    <h2 class="text-2xl font-bold mb-8 text-center">More Plugins</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {others.map((plugin) => (
        <PluginCard plugin={plugin} />
      ))}
    </div>
  </div>
</section>
