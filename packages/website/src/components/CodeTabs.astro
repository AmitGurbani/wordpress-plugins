---
import { Code } from "astro:components";

interface Tab {
  label: string;
  code: string;
  lang: string;
}

interface Props {
  tabs: Tab[];
  id: string;
}

const { tabs, id } = Astro.props;
---

<div class="rounded-xl border border-border overflow-hidden shadow-lg shadow-black/20" data-code-tabs={id}>
  <div class="flex items-center border-b border-border bg-surface-alt/80">
    <div class="flex items-center gap-1.5 px-4 py-3 border-r border-border/50">
      <span class="w-3 h-3 rounded-full bg-red-500/70"></span>
      <span class="w-3 h-3 rounded-full bg-yellow-500/70"></span>
      <span class="w-3 h-3 rounded-full bg-green-500/70"></span>
    </div>
    {tabs.map((tab, i) => (
      <button
        type="button"
        class:list={[
          "px-4 py-3 text-sm font-mono font-medium transition-colors",
          i === 0
            ? "text-accent border-b-2 border-accent bg-surface-card/50"
            : "text-text-muted hover:text-text",
        ]}
        data-tab-button={i}
      >
        {tab.label}
      </button>
    ))}
  </div>
  {tabs.map((tab, i) => (
    <div
      class:list={["[&_pre]:!rounded-none [&_pre]:!border-0 [&_pre]:!m-0 [&_pre]:!py-5 [&_pre]:!px-5 [&_pre]:font-mono", i !== 0 && "hidden"]}
      data-tab-panel={i}
    >
      <Code code={tab.code} lang={tab.lang as any} theme="github-dark" />
    </div>
  ))}
</div>

<script>
  document.querySelectorAll("[data-code-tabs]").forEach((container) => {
    const buttons = container.querySelectorAll<HTMLButtonElement>("[data-tab-button]");
    const panels = container.querySelectorAll<HTMLElement>("[data-tab-panel]");

    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const idx = btn.dataset.tabButton;
        buttons.forEach((b) => {
          const isActive = b.dataset.tabButton === idx;
          b.className = isActive
            ? "px-4 py-3 text-sm font-mono font-medium transition-colors text-accent border-b-2 border-accent bg-surface-card/50"
            : "px-4 py-3 text-sm font-mono font-medium transition-colors text-text-muted hover:text-text";
        });
        panels.forEach((p) => {
          p.classList.toggle("hidden", p.dataset.tabPanel !== idx);
        });
      });
    });
  });
</script>
