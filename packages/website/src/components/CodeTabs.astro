---
import { Code } from "astro:components";

interface Tab {
  label: string;
  code: string;
  lang: string;
}

interface Props {
  tabs: Tab[];
  id: string;
}

const { tabs, id } = Astro.props;
---

<div class="rounded-xl border border-border overflow-hidden" data-code-tabs={id}>
  <div class="flex border-b border-border bg-surface-alt/50">
    {tabs.map((tab, i) => (
      <button
        type="button"
        class:list={[
          "px-4 py-2.5 text-sm font-medium transition-colors",
          i === 0
            ? "text-accent border-b-2 border-accent bg-surface-card/50"
            : "text-text-muted hover:text-text",
        ]}
        data-tab-button={i}
      >
        {tab.label}
      </button>
    ))}
  </div>
  {tabs.map((tab, i) => (
    <div
      class:list={["[&_pre]:!rounded-none [&_pre]:!border-0 [&_pre]:!m-0", i !== 0 && "hidden"]}
      data-tab-panel={i}
    >
      <Code code={tab.code} lang={tab.lang} theme="github-dark" />
    </div>
  ))}
</div>

<script>
  document.querySelectorAll("[data-code-tabs]").forEach((container) => {
    const buttons = container.querySelectorAll<HTMLButtonElement>("[data-tab-button]");
    const panels = container.querySelectorAll<HTMLElement>("[data-tab-panel]");

    buttons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const idx = btn.dataset.tabButton;
        buttons.forEach((b) => {
          const isActive = b.dataset.tabButton === idx;
          b.className = isActive
            ? "px-4 py-2.5 text-sm font-medium transition-colors text-accent border-b-2 border-accent bg-surface-card/50"
            : "px-4 py-2.5 text-sm font-medium transition-colors text-text-muted hover:text-text";
        });
        panels.forEach((p) => {
          p.classList.toggle("hidden", p.dataset.tabPanel !== idx);
        });
      });
    });
  });
</script>
