---
import Layout from "../../layouts/Layout.astro";
import PluginCard from "../../components/PluginCard.astro";
import { plugins, getPluginsByCategory } from "../../data/plugins";

const corePlugins = [
  ...getPluginsByCategory("auth"),
  ...getPluginsByCategory("search"),
  ...getPluginsByCategory("ecommerce"),
];
const analyticsPlugins = getPluginsByCategory("analytics");
---

<Layout title="Plugins — Headless WP Plugins" description="Browse all 8 headless WordPress plugins for WooCommerce stores.">
  <section class="pt-24 pb-20 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <h1 class="text-4xl font-bold mb-4">Plugins</h1>
        <p class="text-lg text-text-muted max-w-xl mx-auto">
          {plugins.length} focused plugins for headless WordPress and WooCommerce stores. Each one does one thing well.
        </p>
      </div>

      <div class="mb-16">
        <h2 class="text-xl font-semibold mb-6 flex items-center gap-3">
          <span class="w-2 h-2 rounded-full bg-emerald-400"></span>
          Core
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
          {corePlugins.map((plugin) => (
            <PluginCard plugin={plugin} />
          ))}
        </div>
      </div>

      <div>
        <h2 class="text-xl font-semibold mb-6 flex items-center gap-3">
          <span class="w-2 h-2 rounded-full bg-violet-400"></span>
          Analytics
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
          {analyticsPlugins.map((plugin) => (
            <PluginCard plugin={plugin} />
          ))}
        </div>
      </div>
    </div>
  </section>
</Layout>
