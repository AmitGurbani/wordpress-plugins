{
  "name": "@amitgurbani/wpts",
  "version": "0.2.0",
  "description": "TypeScript-to-WordPress-Plugin transpiler",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "import": "./dist/src/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "wpts": "bin/wpts.js"
  },
  "files": [
    "dist/",
    "bin/",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && rm -rf dist/src/templates && cp -r src/templates dist/src/templates",
    "dev": "tsc -p tsconfig.build.json --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome lint src/ tests/",
    "check": "biome check src/ tests/",
    "prepublishOnly": "pnpm run build && pnpm run test"
  },
  "keywords": [
    "wordpress",
    "typescript",
    "transpiler",
    "plugin",
    "php"
  ],
  "license": "MIT",
  "author": "Amit Gurbani",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AmitGurbani/wordpress-plugins.git",
    "directory": "packages/wpts"
  },
  "homepage": "https://github.com/AmitGurbani/wordpress-plugins/tree/main/packages/wpts#readme",
  "bugs": {
    "url": "https://github.com/AmitGurbani/wordpress-plugins/issues"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "commander": "^14.0.3",
    "fs-extra": "^11.3.0",
    "handlebars": "^4.7.8",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "^25.3.0",
    "@types/react": "^19.2.14",
    "vitest": "^4.0.18"
  }
}
