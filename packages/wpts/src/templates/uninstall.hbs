<?php

if ( ! defined( 'WP_UNINSTALL_PLUGIN' ) ) {
	exit;
}

{{#each settings}}
delete_option( '{{../functionPrefix}}{{key}}' );
{{/each}}
{{#each activationOptions}}
delete_option( '{{this}}' );
{{/each}}
{{#if diagnosticsErrorOption}}
delete_option( '{{diagnosticsErrorOption}}' );
{{/if}}
{{#each customPostTypes}}

// Delete all {{singularName}} posts and their meta
${{slug}}_posts = get_posts( array( 'post_type' => '{{slug}}', 'posts_per_page' => -1, 'post_status' => 'any', 'fields' => 'ids' ) );
foreach ( ${{slug}}_posts as $id ) {
	wp_delete_post( $id, true );
}
{{/each}}
