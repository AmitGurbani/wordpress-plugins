<?php

if ( ! defined( 'WPINC' ) ) {
	die;
}

class {{className}}_Rest_Api {

	private $namespace;

	public function __construct( $plugin_slug ) {
		$this->namespace = $plugin_slug . '/v1';
	}

	public function register_routes() {
		{{#if hasSettings}}
		register_rest_route(
			$this->namespace,
			'/settings',
			array(
				array(
					'methods'             => 'GET',
					'callback'            => array( $this, 'get_settings' ),
					'permission_callback' => array( $this, 'check_permissions' ),
				),
				array(
					'methods'             => 'POST',
					'callback'            => array( $this, 'update_settings' ),
					'permission_callback' => array( $this, 'check_permissions' ),
				),
			)
		);
		{{/if}}
		{{#each restRoutes}}
		register_rest_route(
			$this->namespace,
			'{{route}}',
			array(
				'methods'             => '{{method}}',
				'callback'            => array( $this, '{{phpMethodName}}' ),
				{{#if public}}
				'permission_callback' => '__return_true',
				{{else}}
				'permission_callback' => function() {
					return current_user_can( '{{capability}}' );
				},
				{{/if}}
			)
		);
		{{/each}}
	}

	{{#if hasSettings}}
	public function check_permissions() {
		return current_user_can( 'manage_options' );
	}

	public function get_settings( $request ) {
		$settings = array(
			{{#each settings}}
			'{{key}}' => {{{phpGetExpression}}},
			{{/each}}
		);

		return rest_ensure_response( $settings );
	}

	public function update_settings( $request ) {
		$params = $request->get_json_params();

		{{#each settings}}
		if ( isset( $params['{{key}}'] ) ) {
			{{#if sanitize}}
			$value = {{sanitize}}( $params['{{key}}'] );
			if ( null === $value ) {
				return new \WP_Error(
					'invalid_{{key}}',
					__( 'Invalid value for {{key}}.', '{{../textDomain}}' ),
					array( 'status' => 400 )
				);
			}
			{{else}}
			$value = $params['{{key}}'];
			{{/if}}
			{{#if sensitive}}
			// GET /settings masks this field as '********'; if the client re-submits
			// the mask (user did not edit it), preserve the existing stored value.
			if ( '********' !== $value ) {
				update_option( '{{../functionPrefix}}{{key}}', $value );
			}
			{{else}}
			update_option( '{{../functionPrefix}}{{key}}', $value );
			{{/if}}
		}
		{{/each}}

		return rest_ensure_response( array( 'success' => true ) );
	}
	{{/if}}

	{{#each restRoutes}}
	public function {{phpMethodName}}( $request ) {
{{{body.phpCode}}}
	}

	{{/each}}
	{{#each restHelperMethods}}
	public function {{phpMethodName}}( {{#each parameters}}{{phpName}}{{#unless @last}}, {{/unless}}{{/each}} ) {
{{{body.phpCode}}}
	}

	{{/each}}
}
